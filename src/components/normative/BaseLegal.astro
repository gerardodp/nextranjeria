---
/**
 * <BaseLegal ref="slug-normativa" articulo="124.1">
 *   Texto opcional de la cita.
 * </BaseLegal>
 *
 * Renderiza un bloque estandarizado que enlaza a la ficha de normativa
 * del sitio. El componente solo muestra la referencia — la normativa
 * vive en la collection `normativa` y se consulta por `ref`.
 */
import { getEntry } from 'astro:content';

interface Props {
  ref: string;
  articulo?: string;
  url?: string;
}

const { ref, articulo, url } = Astro.props;

const entry = await getEntry('normativa', ref).catch(() => null);
const title = entry?.data.shortTitle ?? ref;
const href = url ?? (entry ? `/normativa/${entry.id}/` : undefined);
---

<aside class="base-legal" role="note" aria-label="Base legal">
  <div class="base-legal__label">Base legal</div>
  <div class="base-legal__body">
    {href ? (
      <a href={href} class="base-legal__ref">
        {title}{articulo ? `, art. ${articulo}` : ''}
      </a>
    ) : (
      <span class="base-legal__ref">
        {title}{articulo ? `, art. ${articulo}` : ''}
      </span>
    )}
    {Astro.slots.has('default') && (
      <div class="base-legal__quote"><slot /></div>
    )}
  </div>
</aside>

<style>
  .base-legal {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem 1rem;
    border-left: 3px solid var(--color-brand-700);
    background: var(--color-brand-50);
    padding: 0.85rem 1.1rem;
    margin: 1.5rem 0;
    border-radius: 0 4px 4px 0;
    font-size: 0.95rem;
  }
  .base-legal__label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-800);
    padding-top: 0.15rem;
    white-space: nowrap;
  }
  .base-legal__body {
    color: var(--color-ink);
  }
  .base-legal__ref {
    font-weight: 600;
    color: var(--color-brand-800);
  }
  a.base-legal__ref {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .base-legal__quote {
    margin-top: 0.4rem;
    color: var(--color-ink-soft);
  }
</style>
