---
interface Props {
  title?: string;
}
const { title = 'Paso a paso' } = Astro.props;
---

<section class="paso-a-paso" aria-label={title}>
  <h3 class="paso-a-paso__title">{title}</h3>
  <ol class="paso-a-paso__list">
    <slot />
  </ol>
</section>

<style>
  .paso-a-paso {
    margin: 1.75rem 0;
    padding: 1.1rem 1.3rem;
    background: var(--color-paper-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
  .paso-a-paso__title {
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-brand-800);
    margin: 0 0 0.75rem 0;
  }
  .paso-a-paso__list {
    list-style: none;
    counter-reset: paso;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.7rem;
  }
</style>
