---
interface Props {
  titulo?: string;
  fecha?: string;
}
const { titulo = 'Alerta normativa', fecha } = Astro.props;
---

<aside class="alerta-normativa" role="alert" aria-label={titulo}>
  <div class="alerta-normativa__header">
    <span class="alerta-normativa__badge">{titulo}</span>
    {fecha && <span class="alerta-normativa__fecha">{fecha}</span>}
  </div>
  <div class="alerta-normativa__body"><slot /></div>
</aside>

<style>
  .alerta-normativa {
    margin: 1.75rem 0;
    padding: 1rem 1.2rem;
    background: var(--color-bloque-borrador-bg);
    border: 1px solid var(--color-bloque-borrador-border);
    border-left: 4px solid var(--color-bloque-borrador);
    border-radius: 0 6px 6px 0;
  }
  .alerta-normativa__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .alerta-normativa__badge {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--color-bloque-borrador);
    color: #fff;
    padding: 0.15rem 0.55rem;
    border-radius: 2px;
  }
  .alerta-normativa__fecha {
    font-size: 0.82rem;
    color: var(--color-ink-muted);
  }
  .alerta-normativa__body {
    color: var(--color-ink);
    line-height: 1.6;
  }
  .alerta-normativa__body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
