---
interface Props {
  href?: string;
  title: string;
  description?: string;
  eyebrow?: string;
}
const { href, title, description, eyebrow } = Astro.props;
---

{href ? (
  <a href={href} class="card card--link">
    {eyebrow && <div class="card__eyebrow">{eyebrow}</div>}
    <h3 class="card__title">{title}</h3>
    {description && <p class="card__description">{description}</p>}
    <slot />
  </a>
) : (
  <div class="card">
    {eyebrow && <div class="card__eyebrow">{eyebrow}</div>}
    <h3 class="card__title">{title}</h3>
    {description && <p class="card__description">{description}</p>}
    <slot />
  </div>
)}

<style>
  .card {
    display: block;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.2rem 1.3rem;
    color: inherit;
    text-decoration: none;
    transition: border-color 120ms, box-shadow 120ms, transform 120ms;
  }
  .card--link:hover {
    border-color: var(--color-brand-600);
    box-shadow: 0 1px 3px rgba(15, 23, 42, 0.07);
  }
  .card__eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-700);
    margin-bottom: 0.35rem;
  }
  .card__title {
    margin: 0 0 0.35rem 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.3;
  }
  .card__description {
    margin: 0;
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }
</style>
