---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="breadcrumbs no-print" aria-label="Ruta de navegación">
  <ol>
    {items.map((item, i) => (
      <li>
        {item.href && i < items.length - 1 ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
        {i < items.length - 1 && <span class="breadcrumbs__sep">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    margin-bottom: 1.25rem;
  }
  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .breadcrumbs a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .breadcrumbs a:hover {
    color: var(--color-brand-800);
    text-decoration: underline;
  }
  .breadcrumbs__sep {
    color: var(--color-ink-muted);
  }
  .breadcrumbs [aria-current='page'] {
    color: var(--color-ink);
    font-weight: 500;
  }
</style>
