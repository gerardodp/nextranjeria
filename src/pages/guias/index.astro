---
import ListingLayout from '@layouts/ListingLayout.astro';
import Card from '@components/ui/Card.astro';
import { getPublishedGuides } from '@lib/content';
import type { CollectionEntry } from 'astro:content';

const all = await getPublishedGuides();
const guides = all.sort(
  (a: CollectionEntry<'guides'>, b: CollectionEntry<'guides'>) =>
    a.data.title.localeCompare(b.data.title, 'es'),
);

const crumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Guías por situación' },
];
---

<ListingLayout
  title="Guías por situación"
  seoTitle="Guías de extranjería por situación personal"
  description="Guías pensadas desde la situación personal de quien las lee, no desde la terminología jurídica. Entra por tu caso y te llevamos a las páginas técnicas que necesitas."
  crumbs={crumbs}
>
  {guides.length === 0 ? (
    <div class="empty">
      <p>
        Estamos elaborando las guías por situación. Mientras tanto, puedes
        entrar directamente por alguna de las páginas técnicas:
      </p>
      <ul>
        <li><a href="/regularizacion-2026/">Regularización extraordinaria 2026</a></li>
        <li><a href="/autorizaciones/arraigo-social/">Arraigo social</a></li>
        <li><a href="/tramites/empadronamiento/">Empadronamiento</a></li>
        <li><a href="/normativa/">Normativa vigente</a></li>
        <li><a href="/glosario/">Glosario de términos</a></li>
      </ul>
    </div>
  ) : (
    <div class="grid">
      {guides.map((guide: CollectionEntry<'guides'>) => (
        <Card
          href={`/guias/${guide.id}/`}
          title={guide.data.title}
          description={guide.data.description}
          eyebrow={`${guide.data.estimatedReadTime} min de lectura`}
        />
      ))}
    </div>
  )}
</ListingLayout>

<style>
  .empty {
    padding: 1.5rem 1.75rem;
    background: var(--color-paper-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
  .empty ul {
    margin-bottom: 0;
  }
  .grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
