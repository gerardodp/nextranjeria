---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@components/layout/Breadcrumbs.astro';
import Card from '@components/ui/Card.astro';
import StatusPill from '@components/ui/StatusPill.astro';
import type { CollectionEntry } from 'astro:content';
import { pageUrl } from '@lib/utils';

interface Props {
  title: string;
  description: string;
  hubId: string;
  pages: CollectionEntry<'pages'>[];
  faqs?: CollectionEntry<'faqs'>[];
}

const { title, description, hubId, pages, faqs = [] } = Astro.props;

const crumbs = [
  { label: 'Inicio', href: '/' },
  { label: title },
];
---

<BaseLayout title={title} description={description}>
  <article class="hub-layout">
    <div class="hub-layout__inner">
      <Breadcrumbs items={crumbs} />

      <header class="hub-layout__header">
        <div class="hub-layout__eyebrow">Hub de contenidos</div>
        <h1 class="hub-layout__title">{title}</h1>
        <p class="hub-layout__subtitle">{description}</p>
      </header>

      <section class="hub-layout__grid">
        {pages.map((page) => (
          <Card
            href={pageUrl(page.data.category, page.id, hubId)}
            title={page.data.title}
            description={page.data.description}
          >
            <div class="hub-layout__card-meta">
              <StatusPill status={page.data.normativeStatus} />
            </div>
          </Card>
        ))}
      </section>

      {faqs.length > 0 && (
        <section class="hub-layout__faqs">
          <header class="hub-layout__faqs-header">
            <h2 class="hub-layout__faqs-title">Preguntas frecuentes</h2>
            <p class="hub-layout__faqs-lead">
              Respuestas breves y honestas a las dudas más habituales sobre
              la medida. Cuando no hay certeza, lo decimos.
            </p>
          </header>
          <ul class="hub-layout__faqs-list">
            {faqs.map((faq) => (
              <li class="hub-layout__faqs-item">
                <a class="hub-layout__faqs-link" href={`/faq/${faq.id}/`}>
                  <span class="hub-layout__faqs-question">{faq.data.question}</span>
                  <span class="hub-layout__faqs-short">{faq.data.shortAnswer}</span>
                </a>
              </li>
            ))}
          </ul>
          <a class="hub-layout__faqs-all" href="/faq/">
            Ver todas las preguntas frecuentes →
          </a>
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .hub-layout {
    padding: 2rem 1.5rem 3rem;
  }
  .hub-layout__inner {
    max-width: var(--layout-content);
    margin: 0 auto;
  }
  .hub-layout__eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brand-700);
    margin-bottom: 0.5rem;
  }
  .hub-layout__title {
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 0.65rem 0;
    letter-spacing: -0.02em;
  }
  .hub-layout__subtitle {
    font-size: 1.15rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
    margin: 0 0 2rem 0;
  }
  .hub-layout__grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .hub-layout__card-meta {
    margin-top: 0.75rem;
  }
  .hub-layout__faqs {
    margin-top: 3rem;
  }
  .hub-layout__faqs-header {
    margin-bottom: 1.25rem;
  }
  .hub-layout__faqs-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brand-800);
    margin: 0 0 0.5rem 0;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-brand-200);
  }
  .hub-layout__faqs-lead {
    margin: 0;
    color: var(--color-ink-soft);
    line-height: 1.55;
    font-size: 0.98rem;
  }
  .hub-layout__faqs-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem 0;
    display: grid;
    gap: 0.75rem;
  }
  .hub-layout__faqs-item {
    margin: 0;
  }
  .hub-layout__faqs-link {
    display: block;
    padding: 0.9rem 1.1rem;
    background: var(--color-paper-soft);
    border-left: 3px solid var(--color-brand-500);
    border-radius: 0 4px 4px 0;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .hub-layout__faqs-link:hover {
    background: var(--color-paper);
    border-left-color: var(--color-brand-700);
  }
  .hub-layout__faqs-question {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.35;
    margin-bottom: 0.3rem;
  }
  .hub-layout__faqs-short {
    display: block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    line-height: 1.55;
  }
  .hub-layout__faqs-all {
    display: inline-block;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-brand-700);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-brand-500);
  }
  .hub-layout__faqs-all:hover {
    border-bottom-style: solid;
  }
</style>
